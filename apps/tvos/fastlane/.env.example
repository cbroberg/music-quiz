# ═══════════════════════════════════════════════════════════
# Music Quiz tvOS — Fastlane environment
# ═══════════════════════════════════════════════════════════
# Copy this file to fastlane/.env and fill in real values.
# fastlane/.env is gitignored — NEVER commit it.
# ═══════════════════════════════════════════════════════════

# ─── Apple Developer ─────────────────────────────────────
FASTLANE_TEAM_ID=

# ─── App Store Connect API Key (preferred) ────────────────
# Path is relative to apps/tvos/ (the directory fastlane runs from)
FASTLANE_API_KEY_PATH=fastlane/AuthKey.p8
FASTLANE_API_KEY_ID=
FASTLANE_API_KEY_ISSUER_ID=

# ─── Apple ID fallback (only if no API key) ──────────────
# FASTLANE_APPLE_ID=you@example.com
# FASTLANE_PASSWORD=app-specific-password

# ─── Optional ────────────────────────────────────────────
# Comma-separated TestFlight group names for `release_beta` lane
TESTFLIGHT_GROUPS=

# Discord webhook for build notifications
DISCORD_WEBHOOK_URL=
