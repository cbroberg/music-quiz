# Apple Developer credentials (from https://developer.apple.com/account)
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID

# Private key from MusicKit .p8 file — paste the entire key here
# Replace actual newlines with \n so it fits in one line:
# -----BEGIN PRIVATE KEY-----\nMIGT...base64...\n-----END PRIVATE KEY-----
APPLE_PRIVATE_KEY=

# Apple Music storefront (country code, default: dk)
APPLE_STOREFRONT=dk

# Optional: pre-set a Music User Token (normally obtained via /auth page)
# APPLE_MUSIC_USER_TOKEN=

# Server port (Fly.io uses 3000)
PORT=3000
