    },
    "./home-ws": {
      "types": "./dist/home-ws.d.ts",
      "default": "./dist/home-ws.js"
    },
    "./apple-music": {
      "types": "./dist/apple-music.d.ts",
      "default": "./dist/apple-music.js"
    },
    "./oauth": {
      "types": "./dist/oauth.d.ts",
