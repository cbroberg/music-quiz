    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "default": "./dist/routes.js"
    },
    "./ws-handler": {
      "types": "./dist/ws-handler.d.ts",
      "default": "./dist/ws-handler.js"
    },
    "./browser-ws": {
      "types": "./dist/browser-ws.d.ts",
